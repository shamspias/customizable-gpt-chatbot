# ───────────────────────── Veldra configuration ─────────────────────────
# Copy to .env and fill in. Never commit .env.

# ── LLM provider ─────────────────────────────────────────────────────────
# "ollama" runs fully local (no API key). "anthropic" uses Claude (needs a key).
VELDRA_LLM_PROVIDER=ollama

# ── Ollama (local, default) ──
# Your chat model — set to whatever `ollama list` shows (e.g. qwen3:0.6b).
# NOTE: tiny models (<=1B params) emit schema-valid JSON via constrained decoding
# but make weak agents/specs and unreliable tool calls. For a genuinely usable
# orchestrator, prefer a larger local model (qwen2.5:7b, llama3.1:8b).
VELDRA_OLLAMA_MODEL=qwen3.5:0.8b
VELDRA_OLLAMA_BASE_URL=http://localhost:11434
# Optional: use a stronger local model for the orchestrator (NL->spec) than for agents.
# VELDRA_OLLAMA_ORCHESTRATOR_MODEL=qwen3:1.7b
# Ollama "thinking": off by default — small thinking models over-reason while streaming
# and emit no answer. Set true only with a capable thinking model.
VELDRA_OLLAMA_THINK=false
# Agent loop: auto (decision loop for local/small models, native tool-calling for Claude)
# | decision (force constrained decision loop) | native (force native tool-calling).
VELDRA_AGENT_MODE=auto

# ── Anthropic (optional — only used when VELDRA_LLM_PROVIDER=anthropic) ──
ANTHROPIC_API_KEY=
VELDRA_ORCHESTRATOR_MODEL=claude-opus-4-8
VELDRA_WORKER_MODEL=claude-sonnet-4-6
VELDRA_CHEAP_MODEL=claude-haiku-4-5

# ── Embeddings (local by default) ──
# Pull the embedder first:  ollama pull nomic-embed-text   (768-dim)
# For higher quality, set VELDRA_EMBED_PROVIDER=openai + OPENAI_API_KEY (1536-dim).
# VELDRA_EMBED_PROVIDER: ollama | openai | auto
VELDRA_EMBED_PROVIDER=ollama
VELDRA_OLLAMA_EMBED_MODEL=nomic-embed-text
VELDRA_OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_API_KEY=
# Must match the embedder's dimension: nomic-embed-text=768, text-embedding-3-small=1536.
# Fixed at first migration — changing it later requires re-indexing.
VELDRA_EMBED_DIM=768

# ── Vector store ────────────────────────────────────────────────────────
# pgvector (default, in Postgres) | qdrant. Chunk content + lexical search always
# stay in Postgres; only the vector index moves. To use Qdrant:
#   docker compose -f deploy/docker-compose.yml --profile qdrant up -d
VELDRA_VECTOR_STORE=pgvector
VELDRA_QDRANT_URL=http://localhost:6333
VELDRA_QDRANT_COLLECTION=veldra_chunks

# ── Datastores (match deploy/docker-compose.yml) ────────────────────────
DATABASE_URL=postgresql://veldra:veldra@localhost:5433/veldra
REDIS_URL=redis://localhost:6379/0

# Object storage (MinIO / S3-compatible)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=veldra
S3_SECRET_KEY=veldrasecret
S3_BUCKET=veldra-documents
S3_REGION=us-east-1

# ── App ─────────────────────────────────────────────────────────────────
VELDRA_ENV=local                           # local | stage | prod
VELDRA_API_HOST=0.0.0.0
VELDRA_API_PORT=8000
VELDRA_API_BASE_URL=http://localhost:8000  # used by the CLI + invite links
VELDRA_DEFAULT_TENANT=default              # the default workspace slug
VELDRA_LOG_LEVEL=INFO

# ── Auth & access (multi-user, single workspace) ─────────────────────────
# With auth on, first run shows an install wizard (create the admin + workspace),
# then a sign-in gate. Roles: admin | member | viewer (viewer is read-only).
VELDRA_AUTH_ENABLED=true
VELDRA_SESSION_TTL_DAYS=30
VELDRA_INVITE_TTL_DAYS=7
# Comma-separated allowed browser origins (CORS). Blank => app URL + the Vite dev server.
# VELDRA_CORS_ORIGINS=https://veldra.example.com
# Optional shared token the CLI can send as `Authorization: Bearer <token>` to act as
# the system admin without an interactive login. Blank disables it.
# VELDRA_SERVICE_TOKEN=
# Set false to disable auth entirely (CLI / evals / trusted local single-user dev):
# everything resolves to the default workspace as a system admin, no login required.

# ── Observability (optional) ────────────────────────────────────────────
# OpenTelemetry GenAI tracing. Leave OTEL_EXPORTER_OTLP_ENDPOINT empty to disable export.
OTEL_SERVICE_NAME=veldra
OTEL_EXPORTER_OTLP_ENDPOINT=
