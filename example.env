# ───────────────────────── Loom configuration ─────────────────────────
# Copy to .env and fill in. Never commit .env.

# ── LLM provider ─────────────────────────────────────────────────────────
# "ollama" runs fully local (no API key). "anthropic" uses Claude (needs a key).
LOOM_LLM_PROVIDER=ollama

# ── Ollama (local, default) ──
# Your chat model — set to whatever `ollama list` shows (e.g. qwen3:0.6b).
# NOTE: tiny models (<=1B params) emit schema-valid JSON via constrained decoding
# but make weak agents/specs and unreliable tool calls. For a genuinely usable
# orchestrator, prefer a larger local model (qwen2.5:7b, llama3.1:8b).
LOOM_OLLAMA_MODEL=qwen3.5:0.8b
LOOM_OLLAMA_BASE_URL=http://localhost:11434
# Optional: use a stronger local model for the orchestrator (NL->spec) than for agents.
# LOOM_OLLAMA_ORCHESTRATOR_MODEL=qwen3:1.7b

# ── Anthropic (optional — only used when LOOM_LLM_PROVIDER=anthropic) ──
ANTHROPIC_API_KEY=
LOOM_ORCHESTRATOR_MODEL=claude-opus-4-8
LOOM_WORKER_MODEL=claude-sonnet-4-6
LOOM_CHEAP_MODEL=claude-haiku-4-5

# ── Embeddings (local by default) ──
# Pull the embedder first:  ollama pull nomic-embed-text   (768-dim)
# For higher quality, set LOOM_EMBED_PROVIDER=openai + OPENAI_API_KEY (1536-dim).
# LOOM_EMBED_PROVIDER: ollama | openai | auto
LOOM_EMBED_PROVIDER=ollama
LOOM_OLLAMA_EMBED_MODEL=nomic-embed-text
LOOM_OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_API_KEY=
# Must match the embedder's dimension: nomic-embed-text=768, text-embedding-3-small=1536.
# Fixed at first migration — changing it later requires re-indexing.
LOOM_EMBED_DIM=768

# ── Datastores (match deploy/docker-compose.yml) ────────────────────────
DATABASE_URL=postgresql://loom:loom@localhost:5433/loom
REDIS_URL=redis://localhost:6379/0

# Object storage (MinIO / S3-compatible)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=loom
S3_SECRET_KEY=loomsecret
S3_BUCKET=loom-documents
S3_REGION=us-east-1

# ── App ─────────────────────────────────────────────────────────────────
LOOM_ENV=local                           # local | stage | prod
LOOM_API_HOST=0.0.0.0
LOOM_API_PORT=8000
LOOM_API_BASE_URL=http://localhost:8000  # used by the CLI
LOOM_DEFAULT_TENANT=default              # single-tenant stub for MVP
LOOM_LOG_LEVEL=INFO

# ── Observability (optional) ────────────────────────────────────────────
# OpenTelemetry GenAI tracing. Leave OTEL_EXPORTER_OTLP_ENDPOINT empty to disable export.
OTEL_SERVICE_NAME=loom
OTEL_EXPORTER_OTLP_ENDPOINT=
